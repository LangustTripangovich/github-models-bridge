# Скопируй этот файл в .env и заполни свои значения.
# Никогда не коммить .env в git!

# GitHub Personal Access Token
# Получить: https://github.com/settings/tokens
# Нужные scope:
#   - Classic PAT:        без специального scope (models доступен по умолчанию)
#   - Fine-grained PAT:  Permission → Models → Read
GITHUB_TOKEN=ghp_ВАШ_ТОКЕН_ЗДЕСЬ

# Можно менять модель по умолчанию (необязательно)
# Формат: publisher/model_name
# Примеры:
#   openai/gpt-4.1
#   openai/gpt-4o
#   openai/gpt-4o-mini
#   mistral-ai/mistral-large-2411
#   meta/llama-3.3-70b-instruct
# GITHUB_MODEL=openai/gpt-4.1
